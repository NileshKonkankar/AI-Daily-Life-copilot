rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 200 chars)
    //   - deadline: timestamp (optional)
    //   - priority: string (required, 'low', 'medium', 'high', 'unassigned')
    //   - category: string (required, 'work', 'personal', 'study', 'other')
    //   - status: string (required, 'pending', 'completed')
    //   - userId: string (required, must match auth.uid)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTask(data) {
      let allowedFields = ['title', 'deadline', 'priority', 'category', 'status', 'userId', 'createdAt'];
      let hasRequired = hasRequiredFields(['title', 'priority', 'category', 'status', 'userId', 'createdAt']);
      let onlyAllowed = hasOnlyAllowedFields(allowedFields);
      
      let validTitle = data.title is string && data.title.size() > 0 && data.title.size() <= 200;
      let validPriority = data.priority in ['low', 'medium', 'high', 'unassigned'];
      let validCategory = data.category in ['work', 'personal', 'study', 'other'];
      let validStatus = data.status in ['pending', 'completed'];
      let validUserId = data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128;
      let validCreatedAt = data.createdAt is timestamp;
      
      let validDeadline = !('deadline' in data) || data.deadline == null || data.deadline is timestamp;

      return hasRequired && onlyAllowed && validTitle && validPriority && validCategory && validStatus && validUserId && validCreatedAt && validDeadline;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidTask(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt', 'userId']);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
