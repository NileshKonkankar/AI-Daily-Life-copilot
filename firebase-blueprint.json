{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task created by the user.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task."
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "The deadline for the task."
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "unassigned"],
          "description": "The priority of the task."
        },
        "category": {
          "type": "string",
          "description": "The category of the task (now supports custom string names)."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed"],
          "description": "The current status of the task."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the task."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was created."
        }
      },
      "required": ["title", "priority", "category", "status", "userId", "createdAt"]
    },
    "Category": {
      "title": "Task Category",
      "description": "A custom user-defined category.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the category."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the category."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the category was created."
        }
      },
      "required": ["name", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Collection of user tasks."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Collection of custom user task categories."
    }
  }
}
